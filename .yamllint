---
# Based on ansible-lint config
extends: default

rules:
  braces:
    max-spaces-inside: 1
    level: error

  hyphens:
    level: error

  line-length: disable

  # Required by ansible-lint — must not be loosened.
  comments:
    min-spaces-from-content: 1

  comments-indentation: false

  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
